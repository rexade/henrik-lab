# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── MinIO (internal S3 for Outline file storage) ─────────────────────────────
MINIO_ROOT_PASSWORD=change_me_strong_password

# ── Outline ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
OUTLINE_SECRET_KEY=generate_with_openssl_rand_hex_32
OUTLINE_UTILS_SECRET=generate_with_openssl_rand_hex_32

# Cloudflare Access OIDC (from your Cloudflare Zero Trust dashboard)
OIDC_CLIENT_ID=your_cloudflare_access_client_id
OIDC_CLIENT_SECRET=your_cloudflare_access_client_secret

# Outline API token (create inside Outline under Settings > API)
OUTLINE_TOKEN=ol_api_your_token_here

# ── AI Services ───────────────────────────────────────────────────────────────
# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Domain ────────────────────────────────────────────────────────────────────
# Your root domain, used to build service URLs
DOMAIN=yourdomain.com
