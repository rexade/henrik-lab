# Cloudflare Tunnel configuration template
# Replace TUNNEL_ID with your actual tunnel ID from `cloudflared tunnel list`
# The credentials JSON file is generated by `cloudflared tunnel create <name>`

tunnel: YOUR_TUNNEL_ID
credentials-file: /home/admin/.cloudflared/YOUR_TUNNEL_ID.json

ingress:
  - hostname: ssh.yourdomain.com
    service: ssh://localhost:22

  - hostname: notes.yourdomain.com
    service: http://localhost:3000

  - hostname: home.yourdomain.com
    service: http://localhost:8080

  - hostname: portainer.yourdomain.com
    service: http://localhost:9000

  - hostname: status.yourdomain.com
    service: http://localhost:3001

  - hostname: vault.yourdomain.com
    service: http://localhost:8082

  - hostname: terminal.yourdomain.com
    service: http://localhost:3002

  - hostname: recipes.yourdomain.com
    service: http://localhost:8084

  - hostname: brain.yourdomain.com
    service: http://localhost:8085

  - hostname: files.yourdomain.com
    service: http://localhost:8083

  - service: http_status:404
